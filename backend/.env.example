# Hearth relay — copy to .env (gitignored) and fill in. Both the local `tsx` dev
# server (via dotenv) and docker compose read these.

# Media-search proxy keys (optional — search returns configured:false without them).
GIPHY_KEY=
FREESOUND_KEY=

# Cloudflare Tunnel token — ONLY for the `cloudflare` compose profile. Not needed
# for the Tailscale path (tailscale funnel/serve needs no token). From a named
# tunnel in the Cloudflare Zero Trust dashboard, routed to http://relay:8787.
TUNNEL_TOKEN=

# Image tag to run (CI publishes ghcr.io/spamalot22/hearth-relay:<tag>).
TAG=latest

# Auto-update: shared secret for POST /version. Generate any random string.
RELEASE_SECRET=

# Auto-update download proxy: the relay streams private-repo release assets to
# clients using a read-only GitHub token, so the binaries never need to be public.
# GITHUB_REPO is "owner/repo"; the token needs read-only Contents on that repo.
GITHUB_REPO=spamalot22/hearth
GITHUB_TOKEN=
