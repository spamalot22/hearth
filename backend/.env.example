# Hearth relay — copy to .env (gitignored) and fill in. Both the local `tsx` dev
# server (via dotenv) and docker compose read these.

# Media-search proxy keys (optional — search returns configured:false without them).
GIPHY_KEY=
FREESOUND_KEY=

# Cloudflare Tunnel token, from a named tunnel in the Cloudflare Zero Trust
# dashboard. Route the tunnel's public hostname to http://relay:8787.
TUNNEL_TOKEN=

# Image tag to run (CI publishes ghcr.io/spamalot22/hearth-relay:<tag>).
TAG=latest
