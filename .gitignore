# Env / secrets — never commit these
.env
.env.*
!.env.example
*.pem
*.p8
serviceAccount*.json
google-services.json
GoogleService-Info.plist

# Firebase (future)
.firebase/
*-debug.log

# Claude Code per-machine local settings (not shared)
.claude/settings.local.json
