# macOS
.DS_Store

# Dart / Flutter
.dart_tool/
build/
.flutter-plugins
.flutter-plugins-dependencies

# IDE
.idea/
.vscode/
*.iml

# Node / TypeScript backend (future)
node_modules/
dist/
*.log
# Ignore runtime-written manifest, but track the placeholder seed.
backend/data/*
